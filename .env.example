# ============================================
# 基础配置（单模型，最简方式）
# ============================================
ANTHROPIC_API_KEY=your-api-key-here
ANTHROPIC_BASE_URL=https://your-api-endpoint.com/api
ANTHROPIC_MODEL=your-model-name

# 跳过 npm 安装方式检查警告
DISABLE_INSTALLATION_CHECKS=1

# ============================================
# 多模型配置（可选）
# 配置后可通过 --model 别名 或 /model 别名 切换
# 格式：MODEL_<别名>_NAME / MODEL_<别名>_BASE_URL / MODEL_<别名>_API_KEY
# ============================================

# 豆包
# MODEL_DOUBAO_NAME=doubao-seed-2.0-code
# MODEL_DOUBAO_BASE_URL=https://ark.cn-beijing.volces.com/api/coding
# MODEL_DOUBAO_API_KEY=your-doubao-key

# 智谱 GLM
# MODEL_GLM_NAME=glm-5
# MODEL_GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
# MODEL_GLM_API_KEY=your-glm-key

# MiniMax
# MODEL_MINIMAX_NAME=minimax-text-01
# MODEL_MINIMAX_BASE_URL=https://api.minimax.chat/v1
# MODEL_MINIMAX_API_KEY=your-minimax-key

# DeepSeek
# MODEL_DEEPSEEK_NAME=deepseek-chat
# MODEL_DEEPSEEK_BASE_URL=https://api.deepseek.com
# MODEL_DEEPSEEK_API_KEY=your-deepseek-key
