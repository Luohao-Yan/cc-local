{
  "name": "@cclocal/cli",
  "version": "1.0.0",
  "description": "CCLocal 命令行客户端",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "cclocal": "dist/index.js"
  },
  "scripts": {
    "build": "bun build src/index.ts --outdir dist --target bun",
    "start": "bun run src/index.ts",
    "dev": "bun --watch run src/index.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@cclocal/core": "workspace:*",
    "@cclocal/shared": "workspace:*",
    "react": "^19.1.0",
    "react-reconciler": "0.33.0",
    "ink": "^5.0.0",
    "commander": "^12.0.0",
    "chalk": "^5.4.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/react": "^19.1.0",
    "@types/react-reconciler": "^0.28.0",
    "@types/bun": "^1.3.11",
    "@types/ws": "^8.5.0",
    "typescript": "^5.8.0"
  }
}
